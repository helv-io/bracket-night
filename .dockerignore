# Ignore everything that shouldn't go into Docker context
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.git
.gitignore
.env
.env.*
Dockerfile*
docker-compose*
.dockerignore
.next
out
dist
config
data
.vscode
coverage
*.log
*.pem
*.pid
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.tsbuildinfo

# Keep only what's needed for the multi-stage build
!package*.json
!backend/package*.json
!frontend/package*.json
!backend/src
!frontend
!backend/tsconfig.json
!frontend/tsconfig.json
!frontend/next.config.ts
!frontend/postcss.config.mjs
!frontend/eslint.config.mjs
