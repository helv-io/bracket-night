# Bracket Night Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=development

# Maximum concurrent players per game (default 10)
MAX_PLAYERS=10

# Database location (auto-adjusted for prod/dev)
# DB_FOLDER and DB_PATH are derived from NODE_ENV in code

# === Optional External Services ===

# SearxNG instance for image search (used when creating brackets)
SEARXNG_HOST=searx.example.com

# imgproxy for secure image resizing (required if using SearxNG images)
IMGPROXY_HOST=imgproxy.example.com
IMGPROXY_KEY=your-imgproxy-key
IMGPROXY_SALT=your-imgproxy-salt

# OpenAI-compatible LLM for AI contestant generation (optional)
OPENAI_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
